# Mibo Mental Health - Environment Configuration - DEVELOPMENT

# Backend API Base URL
# For local development:
VITE_API_BASE_URL=http://localhost:5000/api

# For production deployment, change to:
# VITE_API_BASE_URL=https://api.mibo.care/api

# Razorpay Configuration
# Get your test/live keys from Razorpay Dashboard
# Test mode key format: rzp_test_xxxxx
# Live mode key format: rzp_live_xxxxx
# TODO: Replace with your actual Razorpay key from https://dashboard.razorpay.com/app/keys
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxx
